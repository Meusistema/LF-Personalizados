{
  "name": "lukasfe3d-hub",
  "version": "1.0.7",
  "description": "Hub central para gerenciamento do sistema LukasFe3D",
  "author": "Meusistema",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "tsx server.ts",
    "server": "tsx server.ts",
    "electron:dev": "cross-env NODE_ENV=development electron .",
    "electron:build": "npm run build && electron-builder",
    "electron:publish": "npm run build && electron-builder --publish always",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rimraf dist release dist_electron",
    "build:installer": "npm run clean && npm run build && npm run electron:build",
    "lint": "tsc --noEmit",
    "mobile:sync": "npm run build && npx cap sync android",
    "mobile:open": "npx cap open android",
    "mobile:build:apk": "npm run build && npx cap sync android && cd android && ./gradlew assembleDebug",
    "mobile:build:release": "npm run build && npx cap sync android && cd android && ./gradlew assembleRelease"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Meusistema/LF-Personalizados.git"
  },
  "build": {
    "appId": "com.lukasfe3d.hub",
    "productName": "LukasFe3D Hub",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": true,
      "perMachine": false,
      "allowElevation": true,
      "runAfterFinish": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "LukasFe3D Hub"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Meusistema",
        "repo": "LF-Personalizados"
      }
    ],
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ]
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/filesystem": "^8.1.2",
    "@capawesome-team/capacitor-file-opener": "^8.0.1",
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "concurrently": "^9.2.1",
    "core-js": "^3.49.0",
    "dexie": "^4.4.2",
    "dexie-react-hooks": "^4.4.0",
    "dotenv": "^17.2.3",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "express": "^4.21.2",
    "html2canvas": "^1.4.1",
    "html5-qrcode": "^2.3.8",
    "jsbarcode": "^3.12.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^1.4.5-lts.1",
    "postcss": "^8.5.12",
    "qrcode": "^1.5.4",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.0",
    "react-barcode": "^1.6.1",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.1",
    "rimraf": "^6.1.3",
    "vite-plugin-pwa": "^1.2.0",
    "wait-on": "^9.0.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "cross-env": "^10.1.0",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
